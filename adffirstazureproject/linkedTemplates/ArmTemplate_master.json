{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adffirstazureproject"
		},
		"ls_adls_bronze_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_bronze'"
		},
		"ls_blob_raw_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_raw'"
		},
		"ls_sqlserver_local_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlserver_local'"
		},
		"AzureDataLakeStorageGG_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorageGG'"
		},
		"ls_sqlserver_migrationproject_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlserver_migrationproject'"
		},
		"ls_adls_bronze_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsgfirstazureproject.dfs.core.windows.net/"
		},
		"ls_sqlserver_local_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-1J15KOS"
		},
		"ls_sqlserver_local_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ADF_Log"
		},
		"ls_sqlserver_local_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "localdbuser"
		},
		"AzureDataLakeStorageGG_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsgfirstazureproject.dfs.core.windows.net/"
		},
		"ls_sqlserver_migrationproject_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-1J15KOS"
		},
		"ls_sqlserver_migrationproject_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "MigrationProject"
		},
		"ls_sqlserver_migrationproject_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "localdbuser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adffirstazureproject_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_bronze_accountKey": {
						"value": "[parameters('ls_adls_bronze_accountKey')]"
					},
					"ls_blob_raw_connectionString": {
						"value": "[parameters('ls_blob_raw_connectionString')]"
					},
					"AzureDataLakeStorageGG_accountKey": {
						"value": "[parameters('AzureDataLakeStorageGG_accountKey')]"
					},
					"ls_sqlserver_local_password": {
						"value": "[parameters('ls_sqlserver_local_password')]"
					},
					"ls_sqlserver_migrationproject_password": {
						"value": "[parameters('ls_sqlserver_migrationproject_password')]"
					},
					"ls_adls_bronze_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_bronze_properties_typeProperties_url')]"
					},
					"AzureDataLakeStorageGG_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorageGG_properties_typeProperties_url')]"
					},
					"ls_sqlserver_local_properties_typeProperties_server": {
						"value": "[parameters('ls_sqlserver_local_properties_typeProperties_server')]"
					},
					"ls_sqlserver_local_properties_typeProperties_database": {
						"value": "[parameters('ls_sqlserver_local_properties_typeProperties_database')]"
					},
					"ls_sqlserver_local_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqlserver_local_properties_typeProperties_userName')]"
					},
					"ls_sqlserver_migrationproject_properties_typeProperties_server": {
						"value": "[parameters('ls_sqlserver_migrationproject_properties_typeProperties_server')]"
					},
					"ls_sqlserver_migrationproject_properties_typeProperties_database": {
						"value": "[parameters('ls_sqlserver_migrationproject_properties_typeProperties_database')]"
					},
					"ls_sqlserver_migrationproject_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqlserver_migrationproject_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}