{
	"name": "ds_adls_mig_parquet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_adls_bronze",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"TableName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": "@concat(dataset().TableName,'_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.parquet')",
				"folderPath": {
					"value": "@concat(dataset().TableName,'/',formatDateTime(utcNow(),'yyyy/MM/dd'))\n",
					"type": "Expression"
				},
				"fileSystem": "migrationoutput"
			},
			"compressionCodec": "snappy"
		},
		"schema": [
			{
				"name": "ID",
				"type": "UTF8"
			},
			{
				"name": "FirstName",
				"type": "UTF8"
			},
			{
				"name": "LastName",
				"type": "UTF8"
			},
			{
				"name": "Gender",
				"type": "UTF8"
			},
			{
				"name": "Country",
				"type": "UTF8"
			},
			{
				"name": "Age",
				"type": "UTF8"
			}
		]
	}
}